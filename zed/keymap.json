[
  {
    "context": "Editor && vim_mode == normal && !VimWaiting && !VimObject",
    "bindings": {
      "space =": ["workspace::SendKeystrokes", "ctrl-a"],
      "space -": ["workspace::SendKeystrokes", "ctrl-x"],
      "space 1": ["task::Spawn", { "task_name": "harpoon_go_1" }],
      "space 2": ["task::Spawn", { "task_name": "harpoon_go_2" }],
      "space 3": ["task::Spawn", { "task_name": "harpoon_go_3" }],
      "space 4": ["task::Spawn", { "task_name": "harpoon_go_4" }],
      "space 5": ["task::Spawn", { "task_name": "harpoon_go_5" }],
      "space 6": ["task::Spawn", { "task_name": "harpoon_go_6" }],
      "space 7": ["task::Spawn", { "task_name": "harpoon_go_7" }],
      "space 8": ["task::Spawn", { "task_name": "harpoon_go_8" }],
      "space 9": ["task::Spawn", { "task_name": "harpoon_go_9" }],
      "space a": ["task::Spawn", { "task_name": "harpoon_add" }],
      "space o": ["workspace::SendKeystrokes", "o escape k _"],
      "space shift-o": ["workspace::SendKeystrokes", "shift-o escape j _"],
      "space escape": "editor::Cancel",
      "space space b": "pane::CloseOtherItems",
      "space space w": "workspace::SaveWithoutFormat",
      "space space t": "workspace::NewTerminal",
      "space p": ["workspace::SendKeystrokes", "\" _ d shift-p"],
      "space d": ["workspace::SendKeystrokes", "\" _ d"],
      "space q": "workspace::ToggleRightDock",
      "space t": "workspace::ToggleBottomDock",
      "space tab": ["task::Spawn", { "task_name": "harpoon_open" }],
      "space space tab": "tab_switcher::Toggle",
      "space s s": "project_search::SearchInNew",
      "space f s": "buffer_search::Deploy",
      "space f p": "file_finder::Toggle",
      "space g b": "editor::ToggleGitBlameInline",
      "space g a": "git::RestoreFile",
      "space g f": "editor::ExpandAllDiffHunks",
      "space g F": "editor::CollapseAllDiffHunks",
      "space g r": "git::Restore",
      "space f g": ["action::Sequence", ["git_panel::Toggle", "git::Diff"]],
      "space d e": "debug_panel::ToggleFocus",
      "space d d": "editor::ToggleBreakpoint",
      "space d r": "debugger::Start",
      "space d y": "debugger::Stop",
      "space d u": "debugger::Continue",
      "space d j": "debugger::StepOver",
      "space d i": "debugger::StepInto",
      "space d o": "debugger::StepOut",
      "space d h": "debugger::Restart",
      "space w k": "pane::SplitUp",
      "space w j": "pane::SplitDown",
      "space w h": "pane::SplitLeft",
      "space w l": "pane::SplitRight",
      "space w e": "vim::ResetPaneSizes",
      "[ g": "editor::GoToHunk",
      "] g": "editor::GoToPreviousHunk",
      "[ d": "editor::GoToDiagnostic",
      "] d": "editor::GoToPreviousDiagnostic",
      "ctrl-<": "editor::Hover",
      "ctrl-,": "editor::GoToDefinition",
      "ctrl->": "editor::Hover",
      "ctrl-.": "editor::ToggleCodeActions",
      "ctrl-n": "editor::GoToImplementation",
      "ctrl-m": "editor::FindAllReferences",
      "ctrl-o": ["workspace::SendKeystrokes", "ctrl-alt-shift-m ctrl-o z z"],
      "ctrl-i": ["workspace::SendKeystrokes", "ctrl-i z z"],
      "ctrl-s": "workspace::Save",
      "ctrl-shift-p w": "workspace::Save",
      "ctrl-shift-u": "vim::ScrollUp", // Remove after
      "ctrl-u": ["workspace::SendKeystrokes", "ctrl-shift-u z z"],
      "ctrl-shift-d": "vim::ScrollDown", // Remove after
      "ctrl-d": ["workspace::SendKeystrokes", "ctrl-shift-d z z"],
      "shift-g": ["workspace::SendKeystrokes", "shift-g z z"],
      "n": ["workspace::SendKeystrokes", "n z z"],
      "shift-n": ["workspace::SendKeystrokes", "shift-n z z"],
      "f2": "editor::Rename",
      "space f o": "file_finder::Toggle",
      "space f f": "pane::DeploySearch",
      "space b": "tab_switcher::Toggle",
      "space v": "editor::GoToDefinitionSplit",
      "space h": "editor::ToggleInlayHints",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",

      // MacOS
      "space space p": ["workspace::SendKeystrokes", "cmd-v"],
      "space cmd-e": "workspace::ToggleLeftDock",
      "space e": ["workspace::SendKeystrokes", "space cmd-e escape"],
      // Windows
      // "space space p": ["workspace::SendKeystrokes", "ctrl-v"],
      // "space ctrl-e": "workspace::ToggleLeftDock",
      // "space e": ["workspace::SendKeystrokes", "space ctrl-e escape"],
    },
  },
  {
    "context": "OutlinePanel && not_editing",
    "bindings": {
      "j": "menu::SelectNext",
      "k": "menu::SelectPrevious",
      "shift-g": "menu::SelectLast",
      "shift-k": "menu::SelectFirst",
    },
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "j": "menu::SelectNext",
      "k": "menu::SelectPrevious",
      "g g": "menu::SelectFirst",
      "shift-g": "menu::SelectLast",
      "a": "project_panel::NewFile",
      "r": "project_panel::Rename",
      "enter": "project_panel::OpenPermanent",
      "space e": "workspace::ToggleLeftDock",
      "c": "project_panel::Copy",
      "x": "project_panel::Cut",
      "p": "project_panel::Paste",
      "d": ["project_panel::Trash", { "skip_prompt": false }],
      "shift-d": "project_panel::RemoveFromProject",
      "shift-w": "project_panel::CollapseAllEntries",
      "ctrl-q": "tab_switcher::Toggle",
      "alt-l": ["workspace::IncreaseActiveDockSize", { "px": 50 }],
      "alt-h": ["workspace::DecreaseActiveDockSize", { "px": 50 }],
    },
  },
  {
    "context": "Editor && vim_mode == visual && !VimWaiting && !VimObject",
    "bindings": {
      "space p": ["workspace::SendKeystrokes", "\" _ d shift-p"],
      "space d": ["workspace::SendKeystrokes", "\" _ d"],
      "shift-j": "editor::MoveLineDown",
      "shift-k": "editor::MoveLineUp",
      ">": "editor::Indent",
      "<": "editor::Outdent",
      "ctrl-n": [
        "editor::SelectNext",
        {
          "replace_newest": false,
        },
      ],
      "space ctrl-e": "agent::AddSelectionToThread",
      "space ctrl-c": "agent::AddSelectionToThread",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-;": "editor::ToggleComments",
      "ctrl-shift-,": "editor::Hover",
      "ctrl-shift-.": "editor::Hover",
      "alt-h": ["workspace::DecreaseOpenDocksSize", { "px": 50 }],
      "alt-l": ["workspace::IncreaseOpenDocksSize", { "px": 50 }],
      "ctrl-k": "editor::ContextMenuPrevious", // Menu up "editor::ContextMenuFirst"
      "ctrl-j": "editor::ContextMenuNext", // Menu down "editor::ContextMenuLast"

      // MacOS
      "cmd-[": "editor::Outdent",
      "cmd-]": "editor::Indent",
      // Windows
      // "ctrl-[": "editor::Outdent",
      // "ctrl-]": "editor::Indent",
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "ctrl-p": "editor::Paste",
    },
  },
  {
    "context": "Editor && showing_code_actions",
    "bindings": {
      "ctrl-k": "editor::ContextMenuPrevious",
      "ctrl-j": "editor::ContextMenuNext",
    },
  },
  {
    "context": "Editor && showing_completions",
    "bindings": {
      "ctrl-k": "editor::ContextMenuPrevious",
      "ctrl-j": "editor::ContextMenuNext",
    },
  },
  {
    "context": "Editor && vim_mode == normal && !VimWaiting && !VimObject",
    "bindings": {
      "ctrl-j": "workspace::ActivatePaneDown",
    },
  },
  {
    "context": "Editor && showing_code_actions",
    "bindings": {
      "ctrl-k": "editor::ContextMenuPrevious",
      "ctrl-p": "editor::ContextMenuPrevious",
      "ctrl-j": "editor::ContextMenuNext",
      "ctrl-n": "editor::ContextMenuNext",
    },
  },
  {
    "context": "Editor && extension == harpoon && (vim_mode == normal || vim_mode == visual) && !VimWaiting && !VimObject",
    "bindings": {
      "q": [
        "pane::CloseActiveItem",
        { "close_pinned": false, "save_intent": "save_all" },
      ],
    },
  },
  {
    "context": "GitDiff > Editor && vim_mode == normal",
    "bindings": {
      "escape": "project_panel::ToggleFocus",
    },
  },
  {
    "context": "Editor && multibuffer && vim_mode == normal",
    "bindings": {
      "space f f": "search::FocusSearch",
      "space ,": [
        "action::Sequence",
        [
          "editor::OpenExcerpts",
          ["workspace::SendKeystrokes", "z z ctrl-alt-shift-m"],
        ],
      ],
      "q": ["pane::CloseActiveItem", { "close_pinned": false }],
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",
      "escape": "buffer_search::FocusEditor",
      "shift-alt-p": "command_palette::Toggle",

      // MacOS
      "cmd-o": "workspace::Open",
      "cmd-alt-o": "workspace::AddFolderToProject",
      // Windows
      // "ctrl-o": "workspace::Open",
      // "ctrl-alt-o": "workspace::AddFolderToProject",
    },
  },
  {
    "context": "Workspace && !Terminal && !AgentPanel",
    "bindings": {
      // MacOS
      "cmd-t": "workspace::NewWindow",
      "cmd-w": "workspace::CloseWindow",
      // Windows
      // "ctrl-t": "workspace::NewWindow",
      // "ctrl-w": "workspace::CloseWindow",
    },
  },
  {
    "context": "Pane && !Terminal && !AgentPanel",
    "bindings": {
      "ctrl-alt-shift-m": "pane::CloseMultibufferItems",

      // MacOS
      "cmd-w": "workspace::CloseWindow",
      // Windows
      // "ctrl-w": "workspace::CloseWindow",
    },
  },
  {
    "context": "TabSwitcher",
    "bindings": {
      "q": "tab_switcher::CloseSelectedItem",
      "ctrl-q": "tab_switcher::CloseSelectedItem",
    },
  },
  {
    "context": "GitPanel",
    "bindings": {
      "escape": "project_panel::ToggleFocus",
    },
  },
  {
    "context": "GitPanel > Editor",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",
      "escape": "project_panel::ToggleFocus",
    },
  },
  {
    "context": "ProjectSearchBar || ProjectSearchView",
    "bindings": {
      "ctrl-j": "menu::SelectNext",
      "ctrl-k": "menu::SelectPrevious",
      "ctrl-r": "search::ToggleReplace",
      "ctrl-a": "search::ReplaceAll",
    },
  },
  {
    "context": "ProjectSearchView",
    "bindings": {
      "space f f": "project_search::ToggleFocus",
      "ctrl-k": "search::FocusSearch",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "alt-k": ["workspace::IncreaseActiveDockSize", { "px": 60 }],
      "alt-j": ["workspace::DecreaseActiveDockSize", { "px": 60 }],
      "alt-r": ["pane::CloseActiveItem", { "close_pinned": false }],
      "ctrl-tab": "pane::ActivateNextItem",
      "ctrl-shift-tab": "pane::ActivatePreviousItem",
      "ctrl-shift-t": "workspace::ToggleZoom",
      "escape": ["terminal::SendKeystroke", "escape"],
      "ctrl-x escape": "workspace::ToggleBottomDock",
      "ctrl-k": "workspace::ActivatePaneUp",

      // MacOS
      "cmd-w": ["pane::CloseActiveItem", { "close_pinned": false }],
      "cmd-t": "workspace::NewTerminal",
      // Windows
      // "ctrl-w": ["pane::CloseActiveItem", { "close_pinned": false }],
      // "ctrl-p": null,
      // "ctrl-n": null,
      // "ctrl-t": "workspace::NewTerminal",
      // "shift-enter": ["terminal::SendKeystroke", "shift-enter"],
    },
  },
  {
    "context": "AgentPanel",
    "bindings": {
      "ctrl-tab": "agents_sidebar::ToggleThreadSwitcher",
      "ctrl-shift-tab": [
        "agents_sidebar::ToggleThreadSwitcher",
        { "select_last": true },
      ],
      "ctrl-q": "workspace::ToggleRightDock",

      // MacOS
      "cmd-t": "agent::NewThread",
      "cmd-w": "agent::RemoveSelectedThread",
      "cmd-;": "agent::ToggleModelSelector",
      "cmd-.": "agent::ToggleProfileSelector",
      "shift-cmd-h": "workspace::ActivatePaneLeft",
      // Windows
      // "ctrl-t": "agent::NewThread",
      // "ctrl-w": "agent::RemoveSelectedThread",
      // "ctrl-;": "agent::ToggleModelSelector",
      // "ctrl-.": "agent::ToggleProfileSelector",
      // "shift-ctrl-h": "workspace::ActivatePaneLeft",
    },
  },
  {
    "bindings": {
      "ctrl-k": "menu::SelectPrevious",
      "ctrl-j": "menu::SelectNext",
    },
  },
  {
    "context": "ThreadsSidebar",
    "bindings": {
      "ctrl-k": "agents_sidebar::FocusSidebarFilter",
      "alt-h": ["workspace::DecreaseActiveDockSize", { "px": 50 }],
      "alt-l": ["workspace::IncreaseActiveDockSize", { "px": 50 }],
    },
  },
  {
    "context": "ThreadsSidebar && !Editor",
    "bindings": {
      "f": "agents_sidebar::FocusSidebarFilter",
    },
  },
  {
    "context": "ThreadsSidebar > Editor",
    "bindings": {
      "ctrl-j": "menu::Cancel",
      "ctrl-k": "agents_sidebar::FocusSidebarFilter",
      "alt-h": ["workspace::DecreaseActiveDockSize", { "px": 50 }],
      "alt-l": ["workspace::IncreaseActiveDockSize", { "px": 50 }],
    },
  },
  {
    "context": "AgentPanel",
    "bindings": {
      "alt-h": ["workspace::DecreaseActiveDockSize", { "px": 50 }],
      "alt-l": ["workspace::IncreaseActiveDockSize", { "px": 50 }],

      // MacOS
      "cmd-;": "agent::ToggleModelSelector",
      "cmd-.": "agent::ToggleProfileSelector",
      // Windows
      // "ctrl-;": "agent::ToggleModelSelector",
      // "ctrl-.": "agent::ToggleProfileSelector",
    },
  },
  {
    "context": "AcpThread > Editor",
    "bindings": {
      "alt-h": ["workspace::DecreaseActiveDockSize", { "px": 50 }],
      "alt-l": ["workspace::IncreaseActiveDockSize", { "px": 50 }],

      // MacOS
      "cmd-;": "agent::ToggleModelSelector",
      "cmd-.": "agent::ToggleProfileSelector",
      // Windows
      // "ctrl-;": "agent::ToggleModelSelector",
      // "ctrl-.": "agent::ToggleProfileSelector",
    },
  },
]
